<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>CoreByteStudio</title>

  <style>

    body {
      margin: 0;
      padding: 0;
      background-color: #0f1117;
      color: #f1f1f1;
      font-family: Arial, sans-serif;
      line-height: 1.6;
    }

    .container {
      max-width: 900px;
      margin: auto;
      padding: 40px 20px;
    }

    h1, h2, h3 {
      color: #ffffff;
    }

    .hero {
      text-align: center;
      margin-bottom: 50px;
    }

    .hero p {
      color: #bbbbbb;
      max-width: 600px;
      margin: auto;
    }

    .card {
      background: #181c24;
      border-radius: 12px;
      padding: 25px;
      margin-bottom: 25px;
      border: 1px solid #2a2f3a;
    }

    .app-title {
      margin-bottom: 10px;
    }

    .tag {
      display: inline-block;
      background: #2b3445;
      padding: 6px 12px;
      border-radius: 20px;
      margin: 4px;
      font-size: 13px;
    }

    a {
      color: #4da3ff;
      text-decoration: none;
    }

    a:hover {
      text-decoration: underline;
    }

    ul {
      padding-left: 20px;
    }

    .footer {
      margin-top: 50px;
      text-align: center;
      color: #888;
      font-size: 14px;
    }

  </style>
</head>

<body>

  <div class="container">

    <div class="hero">
      <h1>CoreByteStudio</h1>

      <p>
        Mobile software studio focused on professional Android applications,
        utility tools, and specialized mobile solutions.
      </p>
    </div>

    <div class="card">

      <h2>Applications</h2>

      <h3 class="app-title">StitchView Pro</h3>

      <p>
        Professional embroidery file viewer for Android with support for
        multiple embroidery formats and smooth rendering performance.
      </p>

      <div>
        <span class="tag">DST</span>
        <span class="tag">PES</span>
        <span class="tag">JEF</span>
        <span class="tag">VP3</span>
        <span class="tag">EXP</span>
        <span class="tag">XXX</span>
      </div>

      <br>

      <h3>Features</h3>

      <ul>
        <li>Fast embroidery design preview</li>
        <li>Smooth zoom and navigation</li>
        <li>Professional stitch rendering</li>
        <li>Offline support</li>
        <li>Modern Android interface</li>
      </ul>

    </div>

    <div class="card">

      <h2>Support</h2>

      <p>
        For support, business inquiries, or feedback:
      </p>

      <p>
        Email:
        <a href="mailto:studiocorebyte@gmail.com">
          studiocorebyte@gmail.com
        </a>
      </p>

    </div>

    <div class="card">

      <h2>Privacy Policy</h2>

      <p>
        Our applications are designed with user privacy in mind.
      </p>

      <p>
        We do not collect personal information unless explicitly stated
        within the application.
      </p>

      <p>
        Additional privacy details may be provided individually
        for each application.
      </p>

    </div>

    <div class="footer">
      © 2026 CoreByteStudio — Dominican Republic
    </div>

  </div>

</body>
</html>
